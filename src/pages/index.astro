---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HomeSection from '@/components/home/HomeSection.astro';
import PostCard from '@/components/PostCard.astro';
import HomeSidebar from '@/components/home/HomeSidebar.astro';
import AmazonProductCards from '@/components/AmazonProductCards.astro';
import { getPublishedPosts, getActiveDailyDealPost, formatDate } from '@/lib/posts';
import { fetchProductsByAsins } from '@/lib/creators-api';
import { resolveProducts, type ProductEntry } from '@/lib/product-entries';
import { site } from '@/config/site';
import { path } from '@/lib/paths';

const posts = await getPublishedPosts();
const latestPosts = posts.slice(0, 6);
const dailyDealPost = getActiveDailyDealPost(posts);
const HOME_DAILY_DEAL_LIMIT = 10;

const allDailyDealEntries: ProductEntry[] = dailyDealPost
  ? [
      ...(dailyDealPost.data.featuredProduct
        ? [dailyDealPost.data.featuredProduct]
        : []),
      ...(dailyDealPost.data.products ?? []),
    ].map((entry) => ({
      asin: entry.asin,
      price: entry.price,
      imageUrl: entry.imageUrl,
    }))
  : [];
const dailyDealEntries = allDailyDealEntries.slice(0, HOME_DAILY_DEAL_LIMIT);

const dailyDealApiProducts =
  dailyDealEntries.length > 0
    ? await fetchProductsByAsins(dailyDealEntries.map((e) => e.asin))
    : [];
const dailyDealProducts = resolveProducts(dailyDealEntries, dailyDealApiProducts);
---

<BaseLayout
  title={`${site.name} | ${site.homeTitle}`}
  description={site.description}
  pathname="/"
  structuredData="WebSite"
  layout="home"
>
  <div class="home-layout">
    <div class="home-layout__main">
      {
        latestPosts.length > 0 && (
          <HomeSection
            title="Latest"
            subtitle="新着記事"
            moreHref={path('/posts/')}
            id="home-latest"
          >
            <div class="post-list">
              {latestPosts.map((post) => (
                <PostCard post={post} />
              ))}
            </div>
          </HomeSection>
        )
      }

      {
        dailyDealPost && dailyDealProducts.length > 0 && (
          <HomeSection
            title="Daily Deals"
            subtitle={`${formatDate(dailyDealPost.data.pubDate)}の日替わりセール`}
            moreHref={path(`/posts/${dailyDealPost.id}/`)}
            moreLabel="すべて見る"
            id="home-daily-deals"
          >
            <AmazonProductCards
              products={dailyDealProducts}
              entries={dailyDealEntries}
              title="本日の日替わりセール対象"
              showHeading={false}
              variant="covers"
            />
          </HomeSection>
        )
      }

      <HomeSection
        title="About"
        subtitle="このサイトについて"
        moreHref={path('/about/')}
        moreLabel="詳しく"
        id="home-about"
      >
        <p>
          <strong>{site.name}</strong>は、Kindleや電子書籍リーダー、読書アプリを中心に、デジタル読書の楽しみ方とお得な買い方を発信するメディアです。
        </p>
        <p>
          端末レビュー、セール情報、読書術など、電子書籍に関する情報をわかりやすくお届けします。
        </p>
      </HomeSection>
    </div>

    <HomeSidebar />
  </div>
</BaseLayout>
