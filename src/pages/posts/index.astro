---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import { getPublishedPosts } from '@/lib/posts';
import { site } from '@/config/site';

const posts = await getPublishedPosts();
---

<BaseLayout
  title="記事一覧"
  description={`${site.name}の記事一覧。Kindle・電子書籍・読書アプリに関する記事を掲載しています。`}
  pathname="/posts/"
>
  <h1 class="page-title">記事一覧</h1>
  <p class="page-desc">Kindle・電子書籍・読書アプリに関する記事</p>
  {
    posts.length === 0 ? (
      <p>記事を準備中です。</p>
    ) : (
      <div class="post-list">
        {posts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    )
  }
</BaseLayout>
