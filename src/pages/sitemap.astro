---
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  categorySitemapPages,
  staticSitemapPages,
} from '@/lib/sitemap-pages';
import { formatDate, getPublishedPosts } from '@/lib/posts';
import { site } from '@/config/site';
import { path } from '@/lib/paths';

const posts = await getPublishedPosts();
const xmlSitemapUrl = new URL('/sitemap-index.xml', site.url).href;
---

<BaseLayout
  title="サイトマップ"
  description={`${site.name} のページ一覧です。`}
  pathname="/sitemap/"
>
  <div class="container--narrow sitemap-page">
    <h1 class="page-title">サイトマップ</h1>
    <p class="page-desc">{site.name} の公開ページ一覧です。</p>

    <section class="sitemap-section" aria-labelledby="sitemap-static">
      <h2 id="sitemap-static">固定ページ</h2>
      <ul class="sitemap-list">
        {
          staticSitemapPages.map((page) => (
            <li>
              <a href={path(page.href)}>{page.label}</a>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="sitemap-section" aria-labelledby="sitemap-categories">
      <h2 id="sitemap-categories">カテゴリ</h2>
      <ul class="sitemap-list">
        {
          categorySitemapPages.map((page) => (
            <li>
              <a href={path(page.href)}>{page.label}</a>
            </li>
          ))
        }
      </ul>
    </section>

    {
      posts.length > 0 && (
        <section class="sitemap-section" aria-labelledby="sitemap-posts">
          <h2 id="sitemap-posts">記事</h2>
          <ul class="sitemap-list">
            {posts.map((post) => (
              <li>
                <a href={path(`/posts/${post.id}/`)}>{post.data.title}</a>
                <time
                  class="sitemap-list__date"
                  datetime={post.data.pubDate.toISOString()}
                >
                  {formatDate(post.data.pubDate)}
                </time>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <p class="sitemap-xml">
      検索エンジン向け:
      <a href={xmlSitemapUrl}>sitemap-index.xml</a>
    </p>
  </div>
</BaseLayout>
